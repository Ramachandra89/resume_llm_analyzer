# Environment Configuration Template
# Copy this to .env and fill in your AWS credentials

# Model Configuration
# Use one of the following options:
# 1) Local EC2 model directory
# 2) S3 model bucket/prefix
# 3) Hugging Face model ID
MODEL_LOCAL_PATH=./model
S3_MODEL_BUCKET=<your-s3-bucket>
S3_MODEL_PREFIX=<your-s3-prefix>
HUGGINGFACE_MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct
HUGGINGFACE_HUB_TOKEN=<your-huggingface-token>
MODEL_DEVICE=auto
LOAD_IN_8BIT=true

# Optional SageMaker Configuration (legacy)
SAGEMAKER_ENDPOINT_NAME=resume-coach-endpoint
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>

# Backend Configuration
BACKEND_API_URL=http://localhost:8000

# Optional: Custom SageMaker Runtime Region
# AWS_DEFAULT_REGION=us-east-1
